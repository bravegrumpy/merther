---
import { Icon } from "astro-icon/components";
const {articleId = 'latestChapter' , heading, className } = Astro.props;
---

<article id={articleId ?? undefined} class={ className ?? undefined}>
    {heading ? <h2>{heading}</h2> : ""}
  <slot>
    <article>
      <div id="under-construction">
        <p>Please hold while this page is building....</p>
        <p>
          A representative should get back to you with a completed page in 3 to
          5 business weeks.
        </p>
        <p>
          If you don't feel like waiting, <span
            class="return"
            onclick="history.back()">go back to where you came from</span
          >.
        </p>
        <hr />
        <h3>
          Elevator music from the queue starts playing&hellip;
        </h3>
        <div class="text-center">        
          <audio id="player">
            <source id="mp3Source" src="/audio/LeopardPrintElevator.mp3" />
          </audio>
        </div>
        <p style={{textAlign: "center"}}>
          <Icon
            name="svg-spinners:bars-scale-middle"
            size={200}
            style={{color: "#2e045e12"}}
          />
        </p>
        <div class="attributions">
          <details class="attributions-details" open>
            <summary class="menu back-to-top attributions-summary">Music Attribution</summary>
            <ol>
              <li>
                <p>"Leopard Print Elevator" Kevin MacLeod <a target="_blank" class="attribution-anchor" href="https://incompetech.com/music/royalty-free/music.html">(incompetech.com)</a></p>
                <p>Licensed under <a class="attribution-anchor" target="_blank" href="http://creativecommons.org/licenses/by/4.0/">Creative Commons: By Attribution 4.0 License</a></p>
              </li>
              { false && (<>
              <li>
                <p>"Local Forecast - Elevator" Kevin MacLeod <a class="attribution-anchor" target="_blank" href="https://incompetech.com/music/royalty-free/music.html">(incompetech.com)</a></p>
                <p>Licensed under Creative Commons: <a href="http://creativecommons.org/licenses/by/4.0/" target="_blank" class="attribution-anchor">By Attribution 4.0 License</a></p>
              </li>
              </>)
              }
              </ol>
          </details>
        </div>
        <nav class="menu-container tmp-container return">
          <button class="menu back-to-top" onclick="history.back()"
            >Go back
          </button>
        </nav>
      </div>
    </article>
  </slot>
</article>

<style>
  article {
    width: 100%;
  }
    .chnav-container {
        justify-content: center;
    }
    .chnav {
        font-size: 1.5rem;
        width: 40ch;
        height: fit-content;
    }
    .fake-btn:hover {
        opacity: 50%;
    }
    .text-gradient {
        text-align: center;
        width: 100%;
    }
    h2 {
        font-size: 1.9rem;
    }
    .return {
        color: blue;
        text-decoration: underline;
        /* cursor: pointer; */
    }
    details summary::marker {
      display: none;
      content: "";
    }
    .attributions-details {
      width: 100%;
      max-width: 750px;
      margin: 0px auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    summary.attributions-summary {
      width: fit-content;
    }
    .attributions-details ol {
      border: 10px inset #8f5b3680;
    }

    a.attribution-anchor {
      font-size: 1rem;
    }

    li.hidden {
      display: none;
    }
</style>