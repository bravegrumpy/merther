---
import { Icon } from "astro-icon/components";


const frontmatter = Astro.props;
---

<article>
  <slot>
    <article>
      <h2 class="text-gradient">Under Construction</h2>
      <div id="under-construction">
        <p>Please hold while this page is building....</p>
        <p>
          A representative should get back to you with a completed page in 3 to
          5 business weeks.
        </p>
        <p>
          If you don't feel like waiting, <span
            class="return"
            onclick="history.back()">go back to where you came from</span
          >.
        </p>
        <hr />
        <h3>
          Elevator music from the queue starts playing&hellip;<span></span>
        </h3>
        <p style="text-align: center;">
          <Icon
            name="svg-spinners:bars-scale-middle"
            size={200}
            style="color: #2e045e12;"
          />
        </p>
        <nav class="menu-container chnav-container">
          <button class="menu back-to-top chnav" onclick="history.back()"
            >Go back
          </button>
        </nav>
      </div>
    </article>
  </slot>
</article>
