                                {link.children.filter((l1) => l1.type === 'dir')[links.indexOf(link)].href.split('/')[3]}
                            </summary>
                            <ul>
                                {
                                    link.children.map((l1) => (<li>
                                        <a href={l1.href}>{l1.href}</a>
                                        {
                                            l1.children ? (<>
                                                <details open>
