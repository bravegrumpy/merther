                                                    </summary>
                                                    <ul>
                                                        {
                                                            l1.children.map((l2) => (<li>
                                                                <a href={l2.href}>{l2.href}</a>
                                                                {
                                                                    l2.children ? (<>
                                                                        <details open>
                                                                            <summary>
