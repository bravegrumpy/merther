---
import { Icon } from "astro-icon/components"
const { previous='', next='', size='24', previousIcon='hugeicons:arrow-left-04', backToTopIcon = "hugeicons:arrow-up-04", nextIcon="hugeicons:arrow-right-04", other, chapterId } = Astro.props;
---

<div class="end">
    <hr class="middle" />
    <div class="chapter-postnav">
        {
            previous === '' ? (<p class="menu chnav fake-btn">
                <Icon name={previousIcon} width={size} height={size} />
            </p>) : (<>
                <a href={previous} class="menu chnav button"><Icon name={previousIcon} width={size} height={size} /></a>
            </>)
        }
        <a href="#" class="menu chnav button"><Icon name={backToTopIcon} width={size} height={size} /></a>
        {
            next === '' 
                ? (<>
                    <p class="menu chnav fake-btn"><Icon name={nextIcon} width={size} height={size} /></p>
                </>) 
                : (<>
                    <a href={next} class="menu chnav button"><Icon name={nextIcon} width={size} height={size} /></a>
                </>)
        }
    </div>
    <hr />
    <div class="other">
        {
            other === 'single' ?  <a class="menu chnav button" href={`/misunderstood/simple/${chapterId}`}>Single Chapter</a> : <a class="menu chnav button"href={`/misunderstood/simple${chapterId}`}>Entire Work</a>
        }
    </div>
</div>


<style>
.middle {
    position: sticky;
    bottom: 75px;
}
.end {
    background-color: #ff03;
    position: sticky;
    bottom: -53px;
    /* top: 50px; */
    background-color: rgba(162, 143, 124, 98%);
}
.chapter-postnav {
    /* background-color: #f0f2; */
    width: calc(100% + 60px);
    margin-left: -40px;
    display: flex;
    flex-direction: row;
    justify-content: space-between;
}
.button {
    text-indent: 0;
    height: max-content;
}
.other {
    width: 100%;
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: start;
    margin: 40px auto;
}
p  {
    margin-top: 0px;
    margin-bottom: 0px;
}
</style>