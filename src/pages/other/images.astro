---
import Layout from "@/layouts/Layout.astro";
const headTitle = "Images";

import { getCollection, render } from "astro:content"

import { Image } from "astro:assets";

const AiImagaes = await getCollection('gallery_ai');

const imgSize = 300;

---

<Layout headTitle={headTitle}>
    <div slot="pageTitle">
        <h1 class="text-gradient text-center">Gallery</h1>
        <nav class="menu-container">
            <a class="menu" href="/other">Other</a>
            <a class="menu chnav chnav-start" href="/other/images">Images</a>
            <a class="menu" href="/other/css_expo">CSS Expo</a>
        </nav>
    </div>
    <article class="article chapter">
        {
            AiImagaes.map(async (img) => {
                const { Content } = await render(img);
                return (<>
                    <section class="image">
                        <h2>{img.data.title}</h2>
                        { img.data.subtitle ? <p>{img.data.subtitle}</p> : <></>}
                        <Image src={img.data.img.url} alt={img.data.img.alt} width={img.data.img.size} height={img.data.img.size} />
                        <Content />
                    </section>
                </>);
            })
        }
    </article>
</Layout>

<style>
    .article {
        margin-top: 20px;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        grid-template-rows: masonry;
        gap: 60px;
    }
    .image {
        width: 100%;
        background-color:  #25e9e910;;
    }
    .description {
        grid-column: 1 / -1;
        background-color: #6593de30;
    }
    .description h2 {
        text-align: center;
    }
    .description p {
        text-indent: 40px;
        line-height: 2rem;
    }

    @media (max-width: 900px) {
        .article {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 600px) {
        .article {
            grid-template-columns: 1fr;
        }
    }
</style>