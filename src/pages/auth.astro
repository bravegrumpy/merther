---
import Layout from "@/layouts/Layout.astro"
import { auth } from "@/lib/auth"

const session = await auth.api.getSession({
    headers: Astro.request.headers
})
---

<Layout>
    <div class="chapter-preamble">
        <h2>Buttons</h2>
        <button class="menu chnav-start" id="login">Login</button>
        <button class="menu chnav-start" id="logout">Logout</button>
    </div>
    <hr />
    <div class="chapter">
        <script is:inline>
            const { signIn, signOut } = await import("../lib/auth-client");
            document.querySelector("#login").onclick = () => signIn.social({
                provider: 'github',
                callbackURL: "/misunderstood"
            })
            document.querySelector("#logout").onclick = () => signOut()
        </script>
        <h2>{session ? session.user?.name : "No User is Logged In"}</h2>
        {
            session 
                ? (<>
                    <h3>{session.user.name}</h3>
                    <p>Email: {session.user.email}</p>
                </>) 
                : (<></>)
        }
    </div>
</Layout>