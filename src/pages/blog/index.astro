---
import BlogLayout from '@/layouts/BlogLayout.astro';

// import { Button } from "@/components/react/ui/button"

import { xata } from "@/lib/xata";

let posts = await xata.db.posts.getAll();
---

<BlogLayout title="Get started with Xata and Astro">
  <h2><a class="rounded-lg bg-purple-700 text-purple-50 px-5 py-3 font-bold hover:bg-purple-500 hover:text-white hover:ring-4 hover:ring-sky-500" href="/blog/post-list">Posts List</a></h2>
  <div class="w-full max-w-5xl mt-16">
    {posts.length === 0 && <p>No blog posts found</p>}
    {posts.map((post) => (
      <div class="mb-16">
        <p class="text-xs mb-2 text-purple-950 dark:text-purple-200">
          {post.created_at}
        </p>
        <h2 class="text-2xl mb-2">
          <a href={`/blog/${post.slug}`}>{post.title}</a>
        </h2>
        <p class="text-purple-950 dark:text-purple-200 mb-5">
          By: {post.author.xata_id}
        </p>
        <a
          href={`/blog/${post.slug}`}
          class="px-4 py-2 font-semibold text-sm bg-purple-700 text-white rounded-lg shadow-sm w-fit"
        >
          Read more &rarr;
        </a>
      </div>
    ))}
  </div>
  <hr />
</BlogLayout>