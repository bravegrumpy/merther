---
import { Debug } from "astro:components";
import Layout from "@/layouts/Layout.astro"
const headTitle = "Home | Merther";
const pageTitle = "Merther Fanfiction";
const author = null;
import { mainLinks } from "@/scripts/data.js";
import { getCollection, render } from "astro:content";

import Article from "@/components/Article.astro"

import WorkList from "@/pages/pages/content/introduction.mdx"

import { Content as Explicit, frontmatter as explfm}  from "@/pages/pages/content/explicit.mdx"
import { Content as Mature, frontmatter as matfm } from "@/pages/pages/content/mature.mdx";
import { Content as General, frontmatter as genfm } from "@/pages/pages/content/general.mdx"

import { Content as WebRing1, frontmatter as wrfm} from "@/pages/pages/content/webrings.mdx";
import WebRings from "@/components/WebRings.astro";
import FicWebRing from "@/components/FicWebRing.astro";
import FandomRing from "@/components/FandomRing.astro";

const Resources = await getCollection('resources')

import { Image } from "astro:assets"

const siteURL = String(Astro.site);

const renderType = import.meta.env.RENDER_TYPE as string;

---

<Layout headTitle={headTitle} pageTitle={pageTitle} author={author} mainLinks={mainLinks}>
    <script is:inline>

        const closeButton = document.getElementById("close-dialog");

        const agreed = localStorage.getItem("agreed-to-view-adult-content");

        function loadPage() {
            if (agreed === "true") {
                const modal = document.querySelector("dialog");
                modal.open = false;
                const dialogDiv = document.querySelector("div#dialog-body");
                const indexBody = document.querySelector("div#index-body");
                dialogDiv.style.display = "none";
                indexBody.style = undefined;
            } else {
                localStorage.setItem("agreed-to-view-adult-content", false);
                const modal = document.querySelector("div#modal");
                modal.open = true;
                const dialogDiv = document.querySelector("div#dialog-body");
                dialogDiv.style = undefined;
                const indexBody = document.querySelector("div#index-body");
                alert(JSON.stringify(indexBody));
            }
        }
        document.addEventListener("DOMContentLoaded", () => {
            loadPage();
        })
        function closeDialog() {
            const modal = document.querySelector("dialog");
            modal.open = false;
            const dialogBody = document.querySelector("div#dialog-body");
            dialogBody.style.display = "none";
            const indexBody = document.getElementById("index-body")
            indexBody.style = undefined;
            localStorage.setItem("agreed-to-view-adult-content", true);
        }
    </script>
    <dialog id="modal" open>
        <h2>Adult Content</h2>
        <h4 style="text-align: center">This website is unsuitable for persons under the age of 18</h4>
        <p style="text-align: center; font-size: 1.8rem">By proceeding, you confirm that you are at least 18 years of age and consent to view adult content.</p>

        <div class="chapter-preamble-shadow">
            <div class="chapter-preamble">
                <h3>Do you want to continue?</h3>
                <div class="menu-container">
                    <button class="menu back-to-top" style="font-size: 1.5rem" onclick="history.back()">&leftarrow; Go Back</button>
                    <button id="close-dialog" class="menu back-to-top" style="font-size: 1.5rem" onclick="closeDialog()">Proceed &rightarrow;</button>
                </div>
            </div>
        </div>
    </dialog>
    <div class="dialog-body" id="dialog-body"></div>
    <div class="index-body" id="index-body" style="display:none">
    <Article>
        <script is:inline>

            function displayConstructionParagraph() {
                const para = document.getElementById("construction-paragraph");
                if (para) {
                    if (para.style.display === "none") {
                        para.style = undefined;
                    } else {
                        para.style.display = "none";
                    }
                }
            }
        </script>
        <div class="under-construction">
            <button class="menu chnav back-to-top" id="construction-button" onclick="displayConstructionParagraph()">
            <Image src="https://geekring.net/img/undercon.gif" width="50" height="50" alt="Under Construction Gif" />
            </button>
            <p style="display: none" class="construction-paragraph" id="construction-paragraph">This page is <em>always</em> updating and changing, so I guess here is my obligitary &ldquo;old-web&rdquo; under construction disclaimer 😉 </p>
            {
                renderType === "ssg" ? 
                    (<>
                    {/*
                        <hr />
                        <div>
                            <script src="https://ficring.neocities.org/ring.js" is:inline></script>
                        </div>
                    */}
                        <hr />
                        <a class="menu chnav" href="https://merther.bravegrumpy.com/pages">View Site Mirror</a>
                    </>) :
                    (<>
                        <hr />
                        <a class="menu chnav" href="https://mertherfanfic.neocities.org/pages">
                        Visit Neocities Site
                        </a>
                    </>)
            }
        </div>
    </Article>
    <hr class="section" />
    <div class="chapter">
        <Article articleId="worksList">
                <WorkList />
        </Article>
        <hr class="section">
        <Article>
            <Explicit />
            <hr />
            <Mature />
            <hr />
            <General />
            { renderType === "ssg" ?
                (<>
                    <hr class="section" />
                    <div>
                        <WebRing1 />
                    </div>
                </>) :
                (<></>)
            }
        </Article>
    </div>
    <!-- <hr /> -->
    <!-- <div class="links">
        {
            Resources.map(async (list) => {
                const { Content } = await render(list);
                return (<>
                    <Article>
                        <Content />
                    </Article>
                </>);
            })
        }
    </div> -->
    </div>
</Layout>

<style is:global>
    .webring {
        margin: 100px auto;
        width: 100%;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 50px;
    }
</style>
<style>
    dialog {
        background-color: #a28f7c;
    }
    .dialog-body {
        height: 500px;
    }
    div.chapter {
        width: calc(100% - 20px);
    }
    .chapter hr.section {
        width: calc(100% + 60px);
    }
    .links {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px,1fr));
        grid-template-rows: masonry;
        /* flex-direction: column; */
        /* flex-wrap: wrap; */
        gap: 20px;
        /* justify-content: space-evenly; */
        /* align-items: flex-start; */
        /* height: 80ch; */
    }
</style>
<style is:global>
    .under-construction {
        background-color: oklch(83.439% 0.14645 91.939 / 0.103);
        border-radius: 5px;
        width: 50%;
        margin: 0px auto;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        gap: 50px;
        margin-top: 20px;
        border: 2px ridge rgba(31, 7, 51, 0.452);
        padding: 20px 50px;
    }
    .under-construction p {
        width: 200px;
        background-color: rgba(235, 205, 171, 0.623);
        border-radius: 5px;
        border: 2px solid oklch(16.336% 0.06994 299.02 / 0.582);
        padding: 10px;
    }
    .links article {
        border-inline: 20px outset #6848390f;
        border-block: 4px dotted #ed052318  ;
        /* flex-grow: 2; */
        /* background-color: #6299dc60; */
        width: fit-content;
        height: fit-content;
    }
</style>