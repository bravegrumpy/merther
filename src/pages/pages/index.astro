---
import { Debug } from "astro:components";
import Layout from "@/layouts/Layout.astro"
const headTitle = "Home | Merther";
const pageTitle = "Merther Fanfiction";
const author = null;
import { mainLinks } from "@/scripts/data.js";
import { getCollection, render } from "astro:content";

import Article from "@/components/Article.astro"

import WorkList from "@/pages/pages/content/introduction.mdx"

import { Content as Explicit, frontmatter as explfm}  from "@/pages/pages/content/explicit.mdx"
import { Content as Mature, frontmatter as matfm } from "@/pages/pages/content/mature.mdx";
import { Content as General, frontmatter as genfm } from "@/pages/pages/content/general.mdx"

const Resources = await getCollection('resources')

---

<Layout headTitle={headTitle} pageTitle={pageTitle} author={author} mainLinks={mainLinks}>
    <div>
        <Article articleId="worksList">
                <WorkList />
        </Article>
        <hr class="section">
        <Article>
            <Explicit />
            <hr />
            <Mature />
            <hr />
            <General />
        </Article>
    </div>
    <!-- <hr /> -->
    <!-- <div class="links">
        {
            Resources.map(async (list) => {
                const { Content } = await render(list);
                return (<>
                    <Article>
                        <Content />
                    </Article>
                </>);
            })
        }
    </div> -->
</Layout>

<style>
    div.chapter {
        width: calc(100% - 20px);
    }
    .chapter hr.section {
        width: calc(100% + 60px);
    }
    .links {
        width: 100%;
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(210px,1fr));
        grid-template-rows: masonry;
        /* flex-direction: column; */
        /* flex-wrap: wrap; */
        gap: 20px;
        /* justify-content: space-evenly; */
        /* align-items: flex-start; */
        /* height: 80ch; */
    }
</style>
<style is:global>
    .links article {
        border-inline: 20px outset #6848390f;
        border-block: 4px dotted #ed052318  ;
        /* flex-grow: 2; */
        /* background-color: #6299dc60; */
        width: fit-content;
        height: fit-content;
    }
</style>