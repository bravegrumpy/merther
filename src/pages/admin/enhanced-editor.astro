---
import Layout from "@/layouts/Layout.astro";
import { mainLinks } from "@/scripts/data";

const secondaryLinks = [
    {
        id: '04-04-00_Editor',
        href: '/admin/editor',
        text: "Editor"
    },
    {
        id: '04-04-01_MarkdownEditor',
        href: '/admin/markdown-editor',
        text: 'Markdown Editor'
    },
    {
        id: '04-04-02_EnhancedMarkdownEditor',
        href: '/admin/enhanced-editor',
        text: "Enhanced Markdown Editor"
    }
];

import { getCollection } from "astro:content";

// Get all collection names from your content config
const collections = Object.keys(await import.meta.glob("/src/content/config.ts")).length > 0 
  ? Object.keys((await import("@/content.config")).collections)
  : ["misunderstood", "misunderstood_summary", "misunderstood_notes", "misunderstood_endnotes", "muses", "microblog", "gallery_ai", "llorem_ipsum"];

// Authentication check would go here in a real app
const isAuthenticated = true; // Replace with actual auth check
---

<Layout headTitle="Enhanced Markdown Editor | Admin" mainLinks={mainLinks} secondaryLinks={secondaryLinks} bottomInitialDisplay={true}>
  <div slot="pageTitle">
    <h1 class="text-gradient text-center">Enhanced Markdown Editor</h1>
  </div>

  {isAuthenticated ? (
    <div class="editor-container">
      <form id="editor-form" class="editor-form">
        <div class="form-group">
          <label for="collection">Collection:</label>
          <select id="collection" name="collection" required>
            {collections.map(collection => (
              <option value={collection}>{collection}</option>
            ))}
          </select>
        </div>
        
        <div class="form-group">
          <label for="filename">Filename:</label>
          <input type="text" id="filename" name="filename" placeholder="my-file.md" required />
        </div>
        
        <div class="form-group">
          <label for="frontmatter">Frontmatter:</label>
          <div id="frontmatter-editor" class="editor"></div>
        </div>
        
        <div class="form-group">
          <label for="content">Content:</label>
          <div id="content-editor" class="editor"></div>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="save-button">Save</button>
          <div id="status-message"></div>
        </div>
      </form>
      
      <div class="preview-container">
        <h3>Preview</h3>
        <div id="preview" class="markdown-preview"></div>
      </div>
    </div>
  ) : (
    <div class="auth-error">
      <p>You must be logged in to access the editor.</p>
    </div>
  )}
</Layout>

<style>
  .editor-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
  }
  
  .editor-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .form-group label {
    font-weight: bold;
  }
  
  .form-group input,
  .form-group select {
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  
  .editor {
    height: 200px;
    border: 1px solid #ccc;
    border-radius: 4px;
  }
  
  #content-editor {
    height: 400px;
  }
  
  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }
  
  .save-button {
    padding: 0.5rem 1rem;
    background-color: #4a00e0;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
  }
  
  .save-button:hover {
    background-color: #3700b3;
  }
  
  #status-message {
    font-weight: bold;
  }
  
  .preview-container {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 1rem;
    overflow-y: auto;
    height: 800px;
  }
  
  .markdown-preview {
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1.6;
  }
  
  @media (max-width: 768px) {
    .editor-container {
      grid-template-columns: 1fr;
    }
  }
</style>

<!-- Load CodeMirror and marked libraries -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/codemirror@5/lib/codemirror.min.css">
<script is:inline src="https://cdn.jsdelivr.net/npm/codemirror@5/lib/codemirror.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/codemirror@5/mode/markdown/markdown.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/codemirror@5/mode/yaml/yaml.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>

<script>
  // Initialize CodeMirror editors
  const frontmatterEditor = CodeMirror(document.getElementById('frontmatter-editor'), {
    mode: 'yaml',
    lineNumbers: true,
    lineWrapping: true,
    value: `---
title: My New Post
pubDate: ${new Date().toISOString().split('T')[0]}
tags: ['example']
---`
  });
  
  const contentEditor = CodeMirror(document.getElementById('content-editor'), {
    mode: 'markdown',
    lineNumbers: true,
    lineWrapping: true,
    value: '# Hello World\n\nWrite your content here...'
  });
  
  // Update preview when content changes
  const previewEl = document.getElementById('preview');
  
  function updatePreview() {
    if (previewEl) {
      previewEl.innerHTML = marked.parse(contentEditor.getValue());
    }
  }
  
  contentEditor.on('change', updatePreview);
  updatePreview(); // Initial preview
  
  // Handle form submission
  const form = document.getElementById('editor-form');
  const statusMessage = document.getElementById('status-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const collection = document.getElementById('collection').value;
    const filename = document.getElementById('filename').value;
    const frontmatter = frontmatterEditor.getValue();
    const content = contentEditor.getValue();
    
    // Combine frontmatter and content
    const fileContent = `${frontmatter.trim()}\n\n${content}`;
    
    try {
      statusMessage.textContent = 'Saving...';
      
      const response = await fetch('/api/save-markdown', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          collection,
          filename,
          content: fileContent
        }),
      });
      
      if (response.ok) {
        const result = await response.json();
        statusMessage.textContent = `Saved successfully to ${result.path}!`;
        statusMessage.style.color = 'green';
      } else {
        const error = await response.text();
        throw new Error(error);
      }
    } catch (error) {
      statusMessage.textContent = `Error: ${error.message}`;
      statusMessage.style.color = 'red';
    }
  });
</script>