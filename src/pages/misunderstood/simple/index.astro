---
import { Debug } from "astro/components"
import "@fontsource/mr-bedfort"; import "@fontsource/caudex";
import "@fontsource/gloria-hallelujah"; import "@fontsource/cedarville-cursive";
import Layout from "@/layouts/Layout.astro"
import { secondaryLinks } from "@/scripts/data";
const bravegrumpyLink = "https://archiveofourown.org/users/Bravegrumpy/pseuds/BraveGrumpy"

import { Icon } from "astro-icon/components";
const pageTitle = "Misunderstood";
const headTitle = "Misunderstood | Merther"

import Article from "@/components/Article.astro";

import { Chapter, ChapterNav } from "@/components/react/Chapters"
import ChapterPostnav from "@/components/ChapterPostnav.astro"
import { Banner } from "@/components/react/Components"
import { StyleToggle } from "@/components/react/Navigation"

import dayjs from "dayjs";
import utc from "dayjs/plugin/utc"
import advancedFormat from "dayjs/plugin/advancedFormat";
dayjs.extend(utc)
dayjs.extend(advancedFormat);

import { getCollection, render } from "astro:content"

const Misunderstood = await getCollection('misunderstood')

Misunderstood.sort((a, b) => a.data.chapter - b.data.chapter)

const chapters = Misunderstood.map((ch) => ch.data);
const latestChapter = chapters.length - 1;
---
<Layout headTitle={headTitle} pageTitle={pageTitle} secondaryLinks={secondaryLinks} bottomLine={true} link={bravegrumpyLink} >
    <StyleToggle slot="header" client:only="react" />
    <ChapterNav chapters={chapters} icons={true} client:load/>
    <hr class="section" />
    <Article>
         <div class="chapter-preamble latest-chapter">
            <h2 class="text-gradient" style={{paddingLeft:"20px"}}>Latest Chapter: </h2>
            <h3>
                <a href={chapters[latestChapter].href} 
                style={{ color: "#2e045e", fontFamily: "'Delius', 'Recursive',  'Georgia'"}}>{chapters[latestChapter].title}</a>
            </h3>
            <div></div>
         </div>
         <Banner />
    </Article>
    {
        Misunderstood.map(async (chapter) => {
            const { Content, remarkPluginFrontmatter } = await render(chapter);
            const previous = Misunderstood[chapter.data.chapter - 2] ? `/misunderstood/simple${Misunderstood[chapter.data.chapter - 2].data.href}` : '';
            const next = Misunderstood[chapter.data.chapter] ? `/misunderstood/simple${Misunderstood[chapter.data.chapter].data.href}` : '';
            const lastModified = dayjs(remarkPluginFrontmatter.lastModified).utc();
            const readingTime = remarkPluginFrontmatter.minutesRead;
            const pubDate = dayjs(chapter.data.pubDate).utc()
            return (<>
                <Chapter articleId={chapter.data.id} chapterNameHeading={chapter.data.title} previousChapterSrc={previous} nextChapterSrc={next}>
                    <div>
                        <div class="chi">
                            <a class="chb" href={`/misunderstood/simple/${chapter.id}`}>Single Chapter</a>
                            <p class="chb"><span class="notes">Reading Time:</span> {readingTime}</p>
                            <p class="chb"><span class="notes">Last Modified:</span> {lastModified.format('dddd, DD MMMM YYYY')} at {lastModified.format('h:mm a')}</p>
                            <p class="chb"><span class="notes">Published On: {pubDate.format('MMMM Do, YYYY')}</span>{}</p>
                        </div>
                    </div>
                    <Content />
                    <ChapterPostnav previous={previous} next={next} other="single" chapterId={chapter.id} />
                </Chapter>
            </>);
        })
    }
</Layout>

<style>
    .chi {
        width: calc(100% + 60px);
        margin-left: -40px;
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
    }
    .chb {
        vertical-align: middle;
        font-family: 'Delius';
        font-size: 1.2rem;
        text-decoration: none;
        color: currentColor;
    }
    a.chb {
        text-decoration-line: overline underline;
        text-decoration-style: wavy;
        text-decoration-thickness: 3px;
        text-decoration-color: #677040;
    }
    a.chb:hover, a.chb:focus {
        scale: 110%;
        color: #00f;
        text-decoration-line: underline;
        text-decoration-style: wavy;
        text-decoration-thickness: 3px;
    }
    .chapterStats {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-around;
        width: 80ch;
    }
    .text {
        width: fit-content;
        font-family: "Delius", "Recursive";
    }
    .notes {
        font-family: "Delius";
        font-size: 1.2rem;
    }
    @media print {
        .byline, .chi, .cbh, .chapterStats, .text, .notes {
            display: none;
        }
    }
</style>
<style is:global>
    @media print {
        .byline {
            display: none;
        }
    }
</style>
