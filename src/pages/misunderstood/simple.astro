---
import Layout from "@/layouts/Layout.astro"
import { mainLinks, secondaryLinks } from "@/scripts/data";

const pageTitle = "Misunderstood";
const headTitle = "Misunderstood | Merther"

import Article from "@/components/Article.astro";

import { Chapter } from "@/components/react/Chapters"

import Chapter1 from "@/pages/misunderstood/chapters/01_Again.mdx"
import Chapter2 from "@/pages/misunderstood/chapters/02_Hungry.mdx"

import '@fontsource/mr-bedfort'
---
<Layout mainLinks={mainLinks} secondaryLinks={secondaryLinks} pageTitle={pageTitle} headTitle={headTitle}>
    <Chapter client:load articleId="ch01" chapterNameHeading="Chapter 1: Again" previousChapterSrc="#top" nextChapterSrc="#ch02">
        <Chapter1 />
    </Chapter>
    <Chapter client:load articleId="ch02" chapterNameHeading="Chapter 2: Hungry" previousChapterSrc="#ch01" nextChapterSrc="#ch03">
        <Chapter2 />
    </Chapter>
</Layout>