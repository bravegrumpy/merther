---
import "@/styles/global.css"
import UnstyledLayout from "@/layouts/UnstyledLayout.astro";
import { mainLinks, secondaryLinks } from "@/scripts/data";
import { Navigation, Anchor, StyleToggle } from "@/components/react/Navigation";

import { ChapterNav, Chapter, ChapterPreamble } from "@/components/react/Chapters";

import "@fontsource/delius"; import "@fontsource-variable/recursive"; import "@fontsource/style-script"

const headTitle = "Misunderstood | Merther"
const pageTitle = "Misunderstood"

import { getCollection, render } from "astro:content";

import { Footer } from "@/components/react/Components"

const Chapters = await getCollection('misunderstood');
Chapters.sort((a, b) => a.data.chapter - b.data.chapter);

const chapters = Chapters.map((chapter) => chapter.data);

---

<UnstyledLayout pageTitle={pageTitle} headTitle={headTitle} bodyClasses="bg-[url(https://cdn.bravegrumpy.com/AO3Styles/images/topography/topography_brown.png)] bg-background">
    <div class="bg-violet-100/40 w-full lg:w-[120ch] mx-auto py-10">
        <header class="bg-violet-600 text-indigo-50 md:w-[110ch] mx-auto">
            <div class="bg-lime-950 p-4">
                <Navigation client:load id="main-nav" className="flex flex-row flex-wrap gap-1 content-between " >
                    {
                        mainLinks.map((link) => <Anchor href={link.href} keyId={`LinkId_${link.key}`} text={link.text} className="hover:bg-green-200 text-xl font-[Delius] odd:bg-green-300 py-2 text-neutral-800 even:bg-emerald-300 px-4" />)
                    }
                </Navigation>
            </div>
            <div class="bg-black/0">
            <h1 class="font-[Style_Script] text-8xl mx-auto py-5 text-indigo-300 w-fit">Misunderstood</h1>
            </div>
            <div class="mx-auto w-fit">
                <StyleToggle buttonText="▶" showText="▶" hideText="▽" client:load className="mx-auto text-xl hover:text-2xl bg-slate-400 px-10 py-2 font-[Delius] font-bold border-8 border-solid border-slate-500 text-slate-600" />
            </div>
            <div class="flex flex-row flex-wrap gap-5 py-5 pl-13 h-fit" id="top-nav" style="display: none">
                {
                    secondaryLinks.map((link) => (<>
                        <Anchor href={link.href} className="w-[15ch] even:bg-emerald-300 odd:bg-green-300 py-1 text-center px-5 text-neutral-800 text-xl font-[Delius] align-middle border-2 border-solid hover:bg-green-200 border-neutral-800" text={link.text} keyId={link.key} />
                    </>))
                }
            </div>    
        </header>
        <main class="w-[110ch] mx-auto flex flex-col gap-0 ">
            <hr class="w-full h-10 bg-linear-[to_top,var(--color-section-100)_0%,var(--color-section-200)_30%,var(--color-section-300)_50%,var(--color-section-400)_100%]" />
            <ChapterNav client:load chapters={chapters} navClass="px-20 w-[110ch] odd:bg-violet-50 even:bg-green-50 flex flex-row flex-wrap justify-start gap-2 py-5 mx-auto" chapterClass="odd:bg-green-300 even:bg-emerald-300 px-5 py-2 text-lg font-[Delius] hover:bg-green-200 hover:scale-105 hover:-rotate-1 border-2 border-current border-solid" />
            <hr class="border-transparent h-10 bg-linear-[to_top,var(--color-section-100)_0%,var(--color-section-200)_30%,var(--color-section-300)_50%,var(--color-section-400)_100%] sticky top-0" />
            {
                Chapters.map(async (ch) => { 
                    const { Content } = await render(ch);
                    const previous = Chapters[ch.data.chapter - 2] ? Chapters[ch.data.chapter - 2].data.href : '';
                    const next = Chapters[ch.data.chapter] ? Chapters[ch.data.chapter].data.href : '';
                    return (<>
                        <Chapter articleId={ch.data.id} chapterNameHeading={ch.data.title} previousChapterSrc={previous} nextChapterSrc={next} articleClass="even:bg-green-50 odd:bg-violet-50" spanClass="flex flex-row flex-wrap justify-around py-5 px-20 sticky top-10 border-b-2 border-b-solid border-b-current bg-linear-to-r/oklab from-lime-100/85 via-purple-100/85 to-indigo-50/85" anchorClass="odd:bg-emerald-300 even:bg-green-300 px-5 py-2 border-2 border-solid border-current hover:bg-green-200 hover:scale-105 hover:-rotate-1" headingClass="font-[Style_Script] text-3xl" chapterDivClass="prose max-w-none px-20 prose-headings:font-[Delius] prose-h4:text-2xl prose-p:font-[Recursive] prose-hr:h-3 prose-hr:bg-linear-to-r prose-hr:from-purple-600 prose-hr:to-green-600 prose-hr:w-[110ch] prose-hr:-ml-20">
                            <Content />
                            <hr class="not-prose h-10 border-0 border-transparent border-solid bg-linear-[to_top,var(--color-section-100)_0%,var(--color-section-200)_30%,var(--color-section-300)_50%,var(--color-section-400)_100%] w-[110ch] -mx-20 sticky bottom-0" />
                        </Chapter>
                    </>)
                })
            }
        </main>
        <Footer footerClass="w-11/12 bg-violet-600 mx-auto flex flex-row justify-between text-indigo-100" />
    </div>
</UnstyledLayout>