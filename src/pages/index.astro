---
import Layout from '@/layouts/Layout.astro';

const headTitle = "Adult Content | Merther";
const pageTitle = "Merther Fanfiction";
---

<Layout headTitle={headTitle} pageTitle={pageTitle} mainLinks={null} author={null}>
	<div slot="header"><p></p></div>
	<h2>Adult Content</h2>
	<h4 style={{textAlign: "center"}}>This website is unsuitable for persons under the age of 18</h4>
	<p style={{textAlign: "center", fontSize: "1.8rem"}}>By proceeding, you confirm that you are at least 18 years of age and consent to view adult content.</p>
	<div class="chapter-preamble">
		<h3>Do you want to continue?</h3>
		<div class="menu-container">
			<a class="menu back-to-top" style={{fontSize: "1.5rem"}} href="https://neocities.org">&leftarrow; Go Back</a>
			<a class="menu back-to-top" style={{fontSize: "1.5rem"}} href="/pages">Proceed &rightarrow;</a>
		</div>
	</div>
</Layout>
