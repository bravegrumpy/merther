---
import Layout from "@/layouts/Layout.astro";
import { mainLinks } from "@/scripts/data";

const secondaryLinks = [
    {
        id: '04-04-00_Editor',
        href: '/admin/editor',
        text: "Editor"
    },
    {
        id: '04-04-01_MarkdownEditor',
        href: '/admin/markdown-editor',
        text: 'Markdown Editor'
    },
    {
        id: '04-04-02_EnhancedMarkdownEditor',
        href: '/admin/enhanced-editor',
        text: "Enhanced Markdown Editor"
    }
];

import { getCollection } from "astro:content";

// Get all collection names from your content config
const collections = Object.keys(await import.meta.glob("/src/content/config.ts")).length > 0 
  ? Object.keys((await import("@/content.config")).collections)
  : ["misunderstood", "misunderstood_summary", "misunderstood_notes", "misunderstood_endnotes", "muses", "microblog", "gallery_ai", "llorem_ipsum"];

// Authentication check would go here in a real app
const isAuthenticated = true; // Replace with actual auth check
---

<Layout headTitle="Markdown Editor | Admin" mainLinks={mainLinks} secondaryLinks={secondaryLinks} bottomInitialDisplay={true}>
  <div slot="pageTitle">
    <h1 class="text-gradient text-center">Markdown Editor</h1>
  </div>

  {isAuthenticated ? (
    <div class="editor-container">
      <form id="editor-form" class="editor-form">
        <div class="form-group">
          <label for="collection">Collection:</label>
          <select id="collection" name="collection" required>
            {collections.map(collection => (
              <option value={collection}>{collection}</option>
            ))}
          </select>
        </div>
        
        <div class="form-group">
          <label for="filename">Filename:</label>
          <input type="text" id="filename" name="filename" placeholder="my-file.md" required />
        </div>
        
        <div class="form-group">
          <label for="frontmatter">Frontmatter:</label>
          <textarea id="frontmatter" name="frontmatter" rows="8" placeholder="---
title: My New Post
pubDate: 2023-05-17
tags: ['example']
---"></textarea>
        </div>
        
        <div class="form-group">
          <label for="content">Content:</label>
          <textarea id="content" name="content" rows="20" placeholder="Write your markdown content here..."></textarea>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="save-button">Save</button>
          <div id="status-message"></div>
        </div>
      </form>
      
      <div class="preview-container">
        <h3>Preview</h3>
        <div id="preview" class="markdown-preview"></div>
      </div>
    </div>
  ) : (
    <div class="auth-error">
      <p>You must be logged in to access the editor.</p>
    </div>
  )}
</Layout>

<style>
  .editor-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem;
  }
  
  .editor-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  
  .form-group label {
    font-weight: bold;
  }
  
  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.5rem;
    border: 1px solid #ccc;
    border-radius: 4px;
    font-family: 'Courier New', monospace;
  }
  
  .form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1rem;
  }
  
  .save-button {
    padding: 0.5rem 1rem;
    background-color: #4a00e0;
    color: white;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-weight: bold;
  }
  
  .save-button:hover {
    background-color: #3700b3;
  }
  
  #status-message {
    font-weight: bold;
  }
  
  .preview-container {
    border: 1px solid #ddd;
    border-radius: 4px;
    padding: 1rem;
    overflow-y: auto;
  }
  
  .markdown-preview {
    font-family: system-ui, -apple-system, sans-serif;
    line-height: 1.6;
  }
  
  @media (max-width: 768px) {
    .editor-container {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Simple markdown parser (replace with a proper one like marked.js in production)
  function parseMarkdown(markdown) {
    return markdown
      .replace(/^# (.*$)/gm, '<h1>$1</h1>')
      .replace(/^## (.*$)/gm, '<h2>$1</h2>')
      .replace(/^### (.*$)/gm, '<h3>$1</h3>')
      .replace(/^#### (.*$)/gm, '<h4>$1</h4>')
      .replace(/\*\*(.*)\*\*/gm, '<strong>$1</strong>')
      .replace(/\*(.*)\*/gm, '<em>$1</em>')
      .replace(/\n/gm, '<br>');
  }

  // Update preview when content changes
  const contentEl = document.getElementById('content');
  const previewEl = document.getElementById('preview');
  
  contentEl?.addEventListener('input', () => {
    if (previewEl) {
      previewEl.innerHTML = parseMarkdown(contentEl.value);
    }
  });

  // Handle form submission
  const form = document.getElementById('editor-form');
  const statusMessage = document.getElementById('status-message');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const collection = document.getElementById('collection').value;
    const filename = document.getElementById('filename').value;
    const frontmatter = document.getElementById('frontmatter').value;
    const content = document.getElementById('content').value;
    
    // Combine frontmatter and content
    const fileContent = `${frontmatter.trim()}\n\n${content}`;
    
    try {
      statusMessage.textContent = 'Saving...';
      
      const response = await fetch('/api/save-markdown', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          collection,
          filename,
          content: fileContent
        }),
      });
      
      if (response.ok) {
        statusMessage.textContent = 'Saved successfully!';
        statusMessage.style.color = 'green';
      } else {
        const error = await response.text();
        throw new Error(error);
      }
    } catch (error) {
      statusMessage.textContent = `Error: ${error.message}`;
      statusMessage.style.color = 'red';
    }
  });
</script>