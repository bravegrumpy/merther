---
import { Debug } from "astro/components"
import Layout from "@/layouts/Layout.astro"
import { mainLinks, secondaryLinks } from "@/scripts/data"

const { frontmatter } = Astro.props;

import { StyleToggle } from "@/components/react/Navigation";

import { ChapterNav, Chapter } from "@/components/react/Chapters";

const rawChapters = import.meta.glob('@/pages/misunderstood/content/chapters/*.{md,mdx}', { eager: true})
const Misunderstood: any = Object.values(rawChapters)

let chapters = new Array();

Misunderstood.forEach((chapter: any) => {
    chapter.frontmatter.id === 'chapter_index' ? '' : chapters[Misunderstood.indexOf(chapter)] = {
        href: chapter.url,
        text: chapter.frontmatter.text,
        frontmatter: chapter.frontmatter
    }
});

const previous = frontmatter.chapter === 0 ? '' : Misunderstood[frontmatter.chapter - 2] ? Misunderstood[frontmatter.chapter - 2].url : '';

const next = (frontmatter.chapter === 0 || frontmatter.chapter >= Misunderstood.length - 1) ? '' : Misunderstood[frontmatter.chapter].url;

---

<Layout mainLinks={mainLinks} secondaryLinks={secondaryLinks} bottomLine={true}>
    <StyleToggle slot="header" client:load />
    <ChapterNav chapters={chapters} client:load />
    <hr class="section" />
    <Chapter articleId={frontmatter.id} chapterNameHeading={frontmatter.title} previousChapterSrc={previous} nextChapterSrc={next} >
        <slot />
    </Chapter>
</Layout>