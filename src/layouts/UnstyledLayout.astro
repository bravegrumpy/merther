---
// import Analytics from "@vercel/analytics/astro"
const icon = {
  src: "https://cdn.bravegrumpy.com/AO3Styles/images/favicon.png",
};
import img from "@/assets/images/favicon.png";
const { headTitle = "Merther", favicon = icon, bodyClasses='', stopFlash=true} = Astro.props;
---

<!doctype html>
<html>
  <head>
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/texures/TCom_PaperPage0016_2_XXL.png`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/texures/TCom_FabricPatterns0070_S.png`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/texures/TCom_FabricPatterns0112_XL.jpg`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/texures/TCom_FabricPatterns0061_M.jpg`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/texures/TCom_Parquet_XL.png`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/texures/TCom_FabricPatterns0042_M.png`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/candid.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/chromolithograph.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/hand-painted-colorized-heliograph.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/illustration.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/mixture.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/oil-painting.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/render.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/royal-reds.webp`} />
    <link rel="preload" as="image" href={`${Astro.url.host}/api/images/stained-glass.webp`} />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width; initial-scale:1.0;" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="keywords"
      content="fanfiction, writing, smut, pornography, noncon, darkfic"
    />
    <meta name="description" content="Erotic Fanfiction of BBC Merlin" />
    <link rel="icon" href={favicon.src} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Merther Fanfic" href={new URL("rss.xml", Astro.site)} />
    <title>{headTitle}</title>
    <!-- <Analytics /> -->
    <slot name="head" />
    <!-- <script src="../scripts/scrollPosition.js"></script> -->
  </head>
  <body class={bodyClasses} style={{visibility: stopFlash ? 'hidden' : 'visible'}}>
    <script is:inline>0</script>
    <slot />
    <script src="../scripts/visibility.js"></script>
    <noscript>
      <style>
        body {
          visibility: visible;
        }
      </style>
    </noscript>
  </body>
</html>
