---
const icon = {
  src: "https://cdn.bravegrumpy.com/AO3Styles/images/favicon.png",
};
const { headTitle = "Merther", favicon = icon, bodyClasses='' } = Astro.props;
---

<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="keywords"
      content="fanfiction, writing, smut, pornography, noncon, darkfic"
    />
    <meta name="description" content="Erotic Fanfiction of BBC Merlin" />
    <link rel="icon" href={favicon.src} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <title>{headTitle}</title>
    <slot name="head" />
    <slot name="head1" />
  </head>
  <body class={bodyClasses}>
    <slot />
  </body>
</html>
