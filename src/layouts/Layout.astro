---
// stopFlash and Client Router are coupled
// You can have one or the other but not both.
import "@/styles/main.css";
// import "@/styles/global.css";
// import favicon from "@/assets/images/favicon.png"
const favicon = {
  src: "https://cdn.bravegrumpy.com/AO3Styles/images/favicon.png",
};

import { ClientRouter } from "astro:transitions";

import UnstyledLayout from "./UnstyledLayout.astro";

import { Icon } from "astro-icon/components";

import AllSocial from "@/components/AllSocial.astro";
import FicWebRing from "@/components/FicWebRing.astro";
import WR from "@/components/WebRings.astro";
import WebRings from "@/components/FandomRing.astro"

import {
  Navigation,
  Anchor,
  defaultLinks,
  StyleToggle
} from "@/components/react/Navigation";

let {
  headTitle = "Merther",
  pageTitle = "Merther Fanfiction",
  author = "BraveGrumpy",
  link = false,
  frontmatter,
  mainLinks = defaultLinks,
  secondaryLinks,
  topLine = false,
  bottomLine = true,
  topInitialDisplay = "flex",
  bottomInitialDisplay = "none",
  stopFlash=false,
  slug=Astro.url.pathname
} = Astro.props;

headTitle = frontmatter ? frontmatter.headTitle : headTitle;
pageTitle = frontmatter ? frontmatter.pageTitle : pageTitle;
author = frontmatter ? frontmatter.author : author;
link = frontmatter ? frontmatter.link : link;
mainLinks = frontmatter
  ? frontmatter.mainLinks
    ? frontmatter.mainLinks
    : mainLinks
  : mainLinks;
secondaryLinks = frontmatter
  ? frontmatter.secondaryLinks
    ? frontmatter.secondaryLinks
    : secondaryLinks
  : secondaryLinks;
topLine = frontmatter ? frontmatter.topLine : topLine;
bottomLine = frontmatter ? frontmatter.bottomLine : bottomLine;
topInitialDisplay = frontmatter
  ? frontmatter.topInitialDisplay
    ? frontmatter.topInitialDisplay
    : topInitialDisplay
  : topInitialDisplay;
bottomInitialDisplay = frontmatter
  ? frontmatter.bottomInitialDisplay
    ? frontmatter.bottomInitialDisplay
    : bottomInitialDisplay
  : bottomInitialDisplay;

import "@fontsource/delius";
import "@fontsource-variable/recursive";
import "@fontsource/style-script";

import { Footer } from "@/components/react/Components";
import Foot from "@/components/Footer.astro";

const renderType = import.meta.env.RENDER_TYPE;
---
<UnstyledLayout headTitle={headTitle} favicon={favicon} stopFlash={stopFlash}>
  <Fragment slot="head">
    <link rel="stylesheet" href="https://fandomr.ing/onionring/onionring.css">
    <slot name="head" />
    {/* I like ClientRouter better than StopFlash. */}
    { renderType === "ssg" ? <></> : <ClientRouter /> }
     {/* Temporarily putting ClientRouter into Unstyled */}
    <style is:global>
      /* Font fallbacks to prevent CLS - use system fonts until web fonts load */
      *,
      body {
        font-family: "Recursive", "Helvetica", "Courier New", monospace;
      }
      main {
        font-family: "Recursive", "Helvetica", "Courier New", monospace;
      }
      p {
        font-family: "Recursive", "Helvetica", "Courier New", monospace;
      }
      h1, h2 {
        font-family: "Style Script", "Recursive", "Brush Script MT", 'sans-serif';
      }
      h3, h4, h5, h6 {
        font-family: "Delius", "Brush Script MT", "Kurale", "Garamond", serif;
      }
    </style>
    <style>
      .tmp-container {
        justify-content: center;
      }
      .pages-container {
        margin-bottom: 60px;
      }
      .tmp {
        font-size: 1.5rem;
        width: 40ch;
        height: fit-content;
      }
      .fake-btn:hover {
        opacity: 50%;
      }
      .text-gradient {
        text-align: center;
        width: 100%;
      }
      h2 {
        font-size: 1.9rem;
      }
      .return {
        color: blue;
        text-decoration: underline;
        /* cursor: pointer; */
      }
      .back-to-top:hover {
        height: fit-content;
        scale: 105%;
      }
    </style>
  </Fragment>
  <header>
    <script is:inline>
      function toggleMainMenu() {
        const menu = document.querySelector("#main-nav");
        switch(menu.style.display) {
          case 'none':
            menu.style.display = 'flex';
            menu.style.flexDirection = 'column';
            break;
          case 'flex':
            menu.style.display = 'none';
            menu.style.flexDirection = 'unset';
            menu.style.flexWrap = 'unset';
          default:
        }
      }
    </script>
    <button onclick="toggleMainMenu()" id="mainMenuToggle" class="menu pages chnav chnav-start" style={{marginLeft: "70px", width: "calc(100% - 80px);"}}>
      <Icon name="hugeicons:menu-01" />
    </button>
    {
      mainLinks ? (
        <Navigation
          id="main-nav"
          line={topLine}
          displayStyle={topInitialDisplay}
        >
          {mainLinks.map((link: any) => (
            <Anchor keyId={link.key} href={link.href} text={link.text} isActive={slug === link.href} />
          ))}
        </Navigation>
      ) : (
        <p />
      )
    }
    <slot name="pageTitle">
      <h1 class="text-gradient text-center">{pageTitle}</h1>
    </slot>
    <div
      style={{
        display: "flex",
        flexDirection: "row",
        justifyContent: "space-between",
        alignItems: "center",
        paddingBottom: "20px",
      }}
    >
      {
        author ? (
          <p class="byline" style={{ display: "inline", width: "fit-content" }}>
            Written by{" "}
            {link ? (
              <a href={`${link}`} target="_blank">
                {author}
              </a>
            ) : (
              author
            )}
          </p>
        ) : (
          <slot name="author" />
        )
      }
      <slot name="header" />
    </div>
    {
      secondaryLinks ? (
        <Navigation
          id="top-nav"
          line={bottomLine}
          displayStyle={bottomInitialDisplay}
        >
          {secondaryLinks.map((link: any) => (
            <Anchor
              keyId={`secondary_key_${link.key}`}
              href={link.href}
              text={link.text}
            />
          ))}
        </Navigation>
      ) : (
        ""
      )
    }
  </header>
  <main>
    <hr class="section start" />
    <slot>
      <article>
        <h2 class="text-gradient">Under Construction</h2>
        <div id="under-construction">
          <p>Please hold while this page is building....</p>
          <p>
            A representative should get back to you with a completed page in 3
            to 5 business weeks.
          </p>
          <p>
            If you don't feel like waiting, <span
              class="return"
              onclick="history.back()">go back to where you came from</span
            >.
          </p>
          <hr />
          <h3>
            Elevator music from the queue starts playing&hellip;<span></span>
          </h3>
          <p style={{textAlign: "center"}}>
            <Icon
              name="svg-spinners:bars-scale-middle"
              size={200}
              style={{color: "#2e045e12"}}
            />
          </p>
          <nav class="menu-container chnav-container tmp-container">
            <button class="menu back-to-top chnav tmp" onclick="history.back()"
              >Go back
            </button>
          </nav>
        </div>
      </article>
    </slot>
    <hr class="section end" />
  </main>
  <Footer client:load>
    <div class="social" slot="socialLinks">
      <!-- AllSocial / -->
    </div>
  </Footer>
</UnstyledLayout>

<style is:global>
  .social {
    width: fit-content;
    display: flex;
    flex-direction: row;
    gap: 20px;
    flex-wrap: wrap;
    grid-column: 1 / -1;
    margin-bottom: 20px;
  }
  .wrfoot {
    width: fit-content;
    grid-column-start: 2;
    grid-column-end: 4;

  }
</style>