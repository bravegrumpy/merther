---
// This is the copy in the ssr directory

import Analytics from "@vercel/analytics/astro"
import  SpeedInsights  from "@vercel/speed-insights/astro"
// Astro.response.headers.set('Access-Control-Allow-Origin', "*")
// Astro.response.headers.set("Access-Control-Allow-Methods", "GET")
const icon = {
  src: "https://cdn.bravegrumpy.com/AO3Styles/images/favicon.png",
};
import img from "@/assets/images/favicon.png";
const { headTitle = "Merther", favicon = icon, bodyClasses='', stopFlash=true} = Astro.props;
---

<!doctype html>
<html lang="en-us">
  <head>
    <!-- <script src='https://cdn.jsdelivr.net/gh/ncase/nutshell/nutshell.js'></script> -->
    <link rel="preconnect" href="https://cdn.bravegrumpy.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.bravegrumpy.com" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width; initial-scale:1.0;" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="keywords"
      content="fanfiction, writing, smut, pornography, noncon, darkfic"
    />
    <meta name="description" content="Erotic Fanfiction of BBC Merlin" />
    <link rel="icon" href={favicon.src} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Merther Fanfic" href={new URL("rss.xml", Astro.site)} />
    <title>{headTitle}</title>
    <Analytics />
    <SpeedInsights />
    <slot name="head" />

    <!--Preloading fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="preload" href="/_astro/fonts/Recursive-VariableFont_CASL,CRSV,MONO,slnt,wght.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/_astro/fonts/Delius-Regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/_astro/fonts/StyleScript-Regular.woff2" as="font" type="font/woff2" crossorigin>

    <!--Preloading critical background images -->
    <link rel="preload" href="https://cdn.bravegrumpy.com/AO3Styles/images/textures/TCom_FabricPatterns0061_M.jpg" as="image" type="image/jpeg" fetchpriority="high">
    <link rel="preload" href="https://cdn.bravegrumpy.com/AO3Styles/images/textures/TCom_PaperPage0016_2_masked_XXL.png" as="image" type="image/png" fetchpriority="high">
    <link rel="preload" href="https://cdn.bravegrumpy.com/AO3Styles/images/textures/TCom_PaperPage0016_2_masked_XXL_cropped.png" as="image" type="image/png" fetchpriority="high">

    <!-- Add font-display: swap via CSS -->

    <style is:global>
        @font-face {
            font-family: 'Recursive';
            font-display: swap;
        }
        @font-face {
            font-family: 'Delius';
            display: swap;
        }
        @font-face {
            font-family: 'Style Script';
            display: swap;
        }

        /* Preventing content shift for background images */
        /* Reserving space for background images to prevent layout shift */
        [style*="background-image"] {
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* Ensure images have dimensions to prevent CLS */
        img:not([width]):not([height]) {
            aspect-ratio: attr(width) / attr(height);
        }

        img[loading="lazy"] {
            content-visibility: auto;
        }
    </style>
    <!-- <script src="../scripts/scrollPosition.js"></script> -->
  </head>
  <body class={bodyClasses} style={{visibility: stopFlash ? 'hidden' : 'visible'}}>
    <script is:inline>0</script>
    <slot />
    <script src="../scripts/visibility.js"></script>
    <noscript>
      <style>
        body {
          visibility: visible;
        }
      </style>
    </noscript>
  </body>
</html>